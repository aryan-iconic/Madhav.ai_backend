# .env — Copy this to .env and fill in your values
# Never commit the real .env to git!

# ── PostgreSQL ─────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=legal_knowledge_graph
DB_USER=postgres
DB_PASSWORD=your_password_here

# ── Ollama (Local LLM) ─────────────────────────────────
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3        # or: mistral, phi3

# ── LLM Timeout (seconds) ──────────────────────────────
LLM_TIMEOUT=60

# ── API Server ─────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
